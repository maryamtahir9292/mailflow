{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Node",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "devServers",
        "name": "Backend"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Client",
      "type": "shell",
      "command": "Start-Sleep -Seconds 4; npm run dev --prefix client",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "devServers",
        "name": "Frontend"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
