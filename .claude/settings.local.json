{
  "permissions": {
    "allow": [
      "Bash(netstat:*)",
      "Bash(taskkill:*)",
      "Bash(cmd:*)",
      "Bash(powershell.exe -Command \"Get-Process -Id \\(Get-NetTCPConnection -LocalPort 3002\\).OwningProcess | Stop-Process -Force\")",
      "Bash(npm run dev)",
      "Bash(npm install:*)",
      "Bash(cmd.exe /c \"netstat -aon | findstr :3002\")",
      "Bash(cmd.exe /c \"taskkill /F /IM node.exe\" 2>&1 || true)",
      "WebFetch(domain:localhost)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3002/api/csrf-token)",
      "Bash(curl -s http://localhost:3002/api/csrf-token)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3002/api/profile)",
      "Bash(curl -s http://localhost:3002/api/profile)",
      "Bash(npm run:*)",
      "Bash(kill 219)",
      "Bash(pkill -f \"node server.js\")",
      "Bash(pkill -f \"vite\")",
      "Bash(node server.js)",
      "Bash(curl -s http://localhost:5176)",
      "Bash(xargs -I{} taskkill /F /PID {} sleep 2 netstat -ano)"
    ]
  }
}
